{
  "name": "@yario/payment-partner-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Runnable test-environment example of a payment and KYC partner integration with Yario",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm test",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "conformance": "node dist/conformance-cli.js",
    "test": "node --test --test-reporter=spec \"dist/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@yario-ai/integration-sdk": "https://github.com/yario-ai/yario-integration-sdks/releases/download/v0.1.0/yario-ai-integration-sdk-0.1.0.tgz"
  }
}
